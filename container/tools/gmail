#!/usr/bin/env node
/**
 * gmail — Gmail CLI for NanoClaw agents.
 *
 * Usage:
 *   gmail list --label "Newsletter" [--unread] [--max N]   List messages matching label
 *   gmail read --id MSG_ID                                 Get full message as JSON
 *   gmail read-html --id MSG_ID                            Get HTML body (raw, for piping)
 *   gmail modify --id MSG_ID [--add-label LABEL] [--remove-label LABEL]
 *   gmail archive --id MSG_ID                              Archive and mark as read
 *   gmail send --to EMAIL --subject "..." --html-file PATH Send HTML email
 *   gmail labels                                           List all labels
 *
 * Credentials:
 *   OAuth2 refresh token at /workspace/secrets/gmail-oauth.json
 */

import https from 'https';
import fs from 'fs';

const CREDS_PATH = '/workspace/secrets/gmail-oauth.json';

// --- OAuth2 ---

async function getAccessToken(creds) {
  const params = new URLSearchParams({
    client_id: creds.client_id,
    client_secret: creds.client_secret,
    refresh_token: creds.refresh_token,
    grant_type: 'refresh_token',
  });
  const body = params.toString();
  return new Promise((resolve, reject) => {
    const req = https.request('https://oauth2.googleapis.com/token', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Content-Length': Buffer.byteLength(body) },
    }, (res) => {
      let data = '';
      res.on('data', (d) => data += d);
      res.on('end', () => {
        if (res.statusCode !== 200) return reject(new Error(`Auth failed (${res.statusCode}): ${data}`));
        resolve(JSON.parse(data).access_token);
      });
    });
    req.on('error', reject);
    req.write(body);
    req.end();
  });
}

// --- Gmail API ---

async function apiRequest(method, path, token, body) {
  return new Promise((resolve, reject) => {
    const opts = {
      hostname: 'gmail.googleapis.com',
      path,
      method,
      headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
    };
    const req = https.request(opts, (res) => {
      let data = '';
      res.on('data', (d) => data += d);
      res.on('end', () => {
        if (res.statusCode >= 400) return reject(new Error(`API error (${res.statusCode}): ${data}`));
        resolve(data ? JSON.parse(data) : {});
      });
    });
    req.on('error', reject);
    if (body) req.write(JSON.stringify(body));
    req.end();
  });
}

// --- MIME helpers ---

function base64urlDecode(str) {
  // Pad and convert base64url to base64
  let b64 = str.replace(/-/g, '+').replace(/_/g, '/');
  while (b64.length % 4) b64 += '=';
  return Buffer.from(b64, 'base64');
}

function base64urlEncode(buf) {
  return buf.toString('base64').replace(/=/g, '').replace(/\+/g, '-').replace(/\//g, '_');
}

/**
 * Walk the MIME tree and find parts matching a given mimeType.
 */
function findParts(payload, mimeType) {
  const results = [];
  if (payload.mimeType === mimeType && payload.body?.data) {
    results.push(payload);
  }
  if (payload.parts) {
    for (const part of payload.parts) {
      results.push(...findParts(part, mimeType));
    }
  }
  return results;
}

function getHeader(headers, name) {
  const h = headers?.find(h => h.name.toLowerCase() === name.toLowerCase());
  return h ? h.value : null;
}

// --- Label resolution ---

let _labelCache = null;

async function getAllLabels(token) {
  if (_labelCache) return _labelCache;
  const data = await apiRequest('GET', '/gmail/v1/users/me/labels', token);
  _labelCache = data.labels || [];
  return _labelCache;
}

async function labelNameToId(token, name) {
  const labels = await getAllLabels(token);
  const label = labels.find(l => l.name.toLowerCase() === name.toLowerCase());
  if (!label) throw new Error(`Label not found: "${name}". Use "gmail labels" to list available labels.`);
  return label.id;
}

async function labelIdToName(token, id) {
  const labels = await getAllLabels(token);
  const label = labels.find(l => l.id === id);
  return label ? label.name : id;
}

// --- Commands ---

async function cmdList(token, flags) {
  if (!flags.label) {
    console.error('Required: --label LABEL_NAME');
    process.exit(1);
  }

  const labelId = await labelNameToId(token, flags.label);
  const max = parseInt(flags.max || '20', 10);

  const params = new URLSearchParams({
    labelIds: labelId,
    maxResults: String(max),
  });

  if (flags.unread !== undefined) {
    params.set('q', 'is:unread');
  }

  const data = await apiRequest('GET', `/gmail/v1/users/me/messages?${params}`, token);
  const messages = data.messages || [];

  if (messages.length === 0) {
    console.log(JSON.stringify([], null, 2));
    return;
  }

  // Fetch metadata for each message
  const results = [];
  for (const msg of messages) {
    const full = await apiRequest('GET', `/gmail/v1/users/me/messages/${msg.id}?format=METADATA&metadataHeaders=Subject&metadataHeaders=From&metadataHeaders=Date`, token);
    results.push({
      id: full.id,
      subject: getHeader(full.payload?.headers, 'Subject') || '(no subject)',
      from: getHeader(full.payload?.headers, 'From') || '',
      date: getHeader(full.payload?.headers, 'Date') || '',
    });
  }

  console.log(JSON.stringify(results, null, 2));
}

async function cmdRead(token, flags) {
  if (!flags.id) {
    console.error('Required: --id MSG_ID');
    process.exit(1);
  }

  const msg = await apiRequest('GET', `/gmail/v1/users/me/messages/${flags.id}?format=FULL`, token);
  const headers = msg.payload?.headers || [];

  // Extract body parts
  const htmlParts = findParts(msg.payload, 'text/html');
  const textParts = findParts(msg.payload, 'text/plain');

  const bodyHtml = htmlParts.length > 0 ? base64urlDecode(htmlParts[0].body.data).toString('utf-8') : null;
  const bodyText = textParts.length > 0 ? base64urlDecode(textParts[0].body.data).toString('utf-8') : null;

  // Resolve label names
  const labelNames = [];
  for (const id of (msg.labelIds || [])) {
    labelNames.push(await labelIdToName(token, id));
  }

  const result = {
    id: msg.id,
    subject: getHeader(headers, 'Subject') || '(no subject)',
    from: getHeader(headers, 'From') || '',
    date: getHeader(headers, 'Date') || '',
    body_html: bodyHtml,
    body_text: bodyText,
    labels: labelNames,
  };

  console.log(JSON.stringify(result, null, 2));
}

async function cmdReadHtml(token, flags) {
  if (!flags.id) {
    console.error('Required: --id MSG_ID');
    process.exit(1);
  }

  const msg = await apiRequest('GET', `/gmail/v1/users/me/messages/${flags.id}?format=FULL`, token);
  const htmlParts = findParts(msg.payload, 'text/html');

  if (htmlParts.length === 0) {
    // Fall back to text/plain if no HTML
    const textParts = findParts(msg.payload, 'text/plain');
    if (textParts.length > 0) {
      process.stdout.write(base64urlDecode(textParts[0].body.data).toString('utf-8'));
    } else {
      console.error('No HTML or text body found in message.');
      process.exit(1);
    }
    return;
  }

  process.stdout.write(base64urlDecode(htmlParts[0].body.data).toString('utf-8'));
}

async function cmdModify(token, flags) {
  if (!flags.id) {
    console.error('Required: --id MSG_ID');
    process.exit(1);
  }

  const body = { addLabelIds: [], removeLabelIds: [] };

  if (flags['add-label']) {
    body.addLabelIds.push(await labelNameToId(token, flags['add-label']));
  }
  if (flags['remove-label']) {
    body.removeLabelIds.push(await labelNameToId(token, flags['remove-label']));
  }

  if (body.addLabelIds.length === 0 && body.removeLabelIds.length === 0) {
    console.error('Required: --add-label LABEL and/or --remove-label LABEL');
    process.exit(1);
  }

  await apiRequest('POST', `/gmail/v1/users/me/messages/${flags.id}/modify`, token, body);
  console.log('Message labels modified.');
}

async function cmdArchive(token, flags) {
  if (!flags.id) {
    console.error('Required: --id MSG_ID');
    process.exit(1);
  }

  await apiRequest('POST', `/gmail/v1/users/me/messages/${flags.id}/modify`, token, {
    removeLabelIds: ['INBOX', 'UNREAD'],
  });
  console.log('Message archived and marked as read.');
}

async function cmdSend(token, creds, flags) {
  if (!flags.to || !flags.subject || !flags['html-file']) {
    console.error('Required: --to EMAIL --subject "..." --html-file PATH');
    process.exit(1);
  }

  if (!fs.existsSync(flags['html-file'])) {
    console.error(`HTML file not found: ${flags['html-file']}`);
    process.exit(1);
  }

  const htmlBody = fs.readFileSync(flags['html-file'], 'utf-8');
  const from = creds.email || 'me';

  // Construct MIME message
  const mime = [
    `From: ${from}`,
    `To: ${flags.to}`,
    `Subject: ${flags.subject}`,
    'MIME-Version: 1.0',
    'Content-Type: text/html; charset="UTF-8"',
    'Content-Transfer-Encoding: base64',
    '',
    Buffer.from(htmlBody, 'utf-8').toString('base64'),
  ].join('\r\n');

  const raw = base64urlEncode(Buffer.from(mime, 'utf-8'));

  const result = await apiRequest('POST', '/gmail/v1/users/me/messages/send', token, { raw });
  console.log(`Message sent. ID: ${result.id}`);
}

async function cmdLabels(token) {
  const labels = await getAllLabels(token);
  const sorted = labels.sort((a, b) => a.name.localeCompare(b.name));
  const result = sorted.map(l => ({ id: l.id, name: l.name, type: l.type }));
  console.log(JSON.stringify(result, null, 2));
}

// --- CLI ---

function parseArgs(args) {
  const result = { command: args[0], flags: {} };
  for (let i = 1; i < args.length; i++) {
    if (args[i].startsWith('--')) {
      const key = args[i].slice(2);
      // Check if next arg exists and is not a flag (boolean flag support)
      if (i + 1 < args.length && !args[i + 1].startsWith('--')) {
        result.flags[key] = args[i + 1];
        i++;
      } else {
        result.flags[key] = true;
      }
    }
  }
  return result;
}

async function main() {
  const args = process.argv.slice(2);
  if (args.length === 0 || args[0] === '--help') {
    console.log(`Usage:
  gmail list --label "Newsletter" [--unread] [--max N]   List messages matching label
  gmail read --id MSG_ID                                 Get full message as JSON
  gmail read-html --id MSG_ID                            Get HTML body (raw, for piping)
  gmail modify --id MSG_ID [--add-label LABEL] [--remove-label LABEL]
  gmail archive --id MSG_ID                              Archive and mark as read
  gmail send --to EMAIL --subject "..." --html-file PATH Send HTML email
  gmail labels                                           List all labels`);
    process.exit(0);
  }

  if (!fs.existsSync(CREDS_PATH)) {
    console.error(`OAuth credentials not found at: ${CREDS_PATH}`);
    process.exit(1);
  }

  const creds = JSON.parse(fs.readFileSync(CREDS_PATH, 'utf-8'));
  const token = await getAccessToken(creds);
  const { command, flags } = parseArgs(args);

  switch (command) {
    case 'list':
      await cmdList(token, flags);
      break;
    case 'read':
      await cmdRead(token, flags);
      break;
    case 'read-html':
      await cmdReadHtml(token, flags);
      break;
    case 'modify':
      await cmdModify(token, flags);
      break;
    case 'archive':
      await cmdArchive(token, flags);
      break;
    case 'send':
      await cmdSend(token, creds, flags);
      break;
    case 'labels':
      await cmdLabels(token);
      break;
    default:
      console.error(`Unknown command: ${command}. Run gmail --help for usage.`);
      process.exit(1);
  }
}

main().catch((err) => { console.error(err.message); process.exit(1); });
